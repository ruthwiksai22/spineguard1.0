generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Patient {
  id        String   @id @default(uuid())
  patientId String
  name      String
  age       Int?
  createdAt DateTime @default(now())
  scans     Scan[]

  @@map("patients")
}

model Scan {
  id            String     @id @default(uuid())
  patientCaseId String
  patient       Patient    @relation(fields: [patientCaseId], references: [id])
  imageUrl      String
  imageType     String
  metadata      Json?      
  uploadedAt    DateTime   @default(now())
  analyses      Analysis[]

  @@map("scans")
}

model Analysis {
  id         String   @id @default(uuid())
  scanId     String
  scan       Scan     @relation(fields: [scanId], references: [id])
  results    Json     
  analyzedAt DateTime @default(now())

  @@map("analyses")
}

model User {
  id       String  @id @default(uuid())
  username String  @unique
  password String

  @@map("users")
}
